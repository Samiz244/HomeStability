# Copy to .env and fill in. The server runs WITHOUT a key (graceful fallback
# responses), and automatically uses real AI when GROQ_API_KEY is set.

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Groq model. Default is a current production model.
# Other options: llama-3.1-8b-instant, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Server port (frontend dev proxy expects 3001)
PORT=3001

# OPTIONAL Postgres. Leave blank to run on in-memory/mock data (no setup needed).
# When set and reachable, all services persist to Postgres automatically.
# DATABASE_URL=postgresql://username:password@localhost:5432/housing_stability
NODE_ENV=development
